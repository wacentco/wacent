{
  "name": "@wacent/node",
  "version": "0.1.0",
  "description": "Official Node.js SDK for WACENT — WhatsApp API & Messaging Platform",
  "keywords": [
    "whatsapp",
    "api",
    "sdk",
    "messaging",
    "WACENT"
  ],
  "author": "WACENT <hello@wacent.io>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/WACENT/WACENT"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
