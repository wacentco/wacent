{
  "name": "WACENT",
  "private": true,
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "db:migrate": "pnpm --filter @wacent/db migrate",
    "db:generate": "pnpm --filter @wacent/db generate",
    "db:studio": "pnpm --filter @wacent/db studio",
    "db:seed": "pnpm --filter @wacent/db seed"
  },
  "devDependencies": {
    "turbo": "^2.0.0",
    "typescript": "^5.4.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.0.0"
}
