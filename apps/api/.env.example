# Server
PORT=8000
NODE_ENV=development

# Database
DATABASE_URL=postgresql://wacent:secret@localhost:5432/wacent

# Redis tidak dipakai di API — semua queue dihandle oleh worker

# Worker connection
WORKER_URL=http://localhost:3001
WORKER_SECRET=change_me_random_32char_string

# Auth / Encryption
JWT_SECRET=change_me_random_32char_string
SESSION_ENCRYPTION_KEY=change_me_32char_aes_key_here!

# Stripe (billing)
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Email (SMTP)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@your-domain.com
SMTP_PASS=smtp_password_here
SMTP_FROM=noreply@your-domain.com

# CORS
FRONTEND_URL=http://localhost:3000

# Seed script — first admin user (used by pnpm db:seed)
ADMIN_EMAIL=admin@your-domain.com
ADMIN_PASSWORD=ChangeThisPassword!2024

# Device Warmer pool (comma-separated E.164 numbers)
WARM_POOL_NUMBERS=+628xxxxxxxxxx,+628yyyyyyyyyy

# AWS S3 / Cloudflare R2 (for media uploads)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=auto
AWS_S3_BUCKET=wacent-media
AWS_S3_ENDPOINT=https://xxx.r2.cloudflarestorage.com
